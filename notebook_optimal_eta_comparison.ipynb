    "T = 10000\n",
    "wsd = WSDSchedule(steps=T, base_lr=eta, cooldown_len=0.2)\n",
    "constant = ConstantSchedule(steps=T, base_lr=eta)\n",
    "linear = WSDSchedule(steps=T, base_lr=eta, cooldown_len=1.)\n",
    "\n",
    "\n",
    "for exponent in np.linspace(1.1, 2, 10):\n",
    "    model = PowerLawRegression(dim=dim, sigma=sigma, exponent=exponent)\n",
    "    computations_SGD = Computations(model, schedules=[wsd, constant, linear], schedules_names=[\"wsd\", \"constant\", \"linear\"], sgd_class=SGD)\n",
    "    computations_SGD.optimize_all_base_lrs(x0, change_eta=True, eta_range=eta_range, save_results=True, plot=False)\n",
    "    \n",
    "    print(computations_SGD.last_optimization_file)\n",
    "\n",
    "    computations_noisyGD = Computations(model, schedules=[wsd, constant, linear], schedules_names=[ \"wsd\", \"constant\", \"linear\"], sgd_class=NoisyGD)\n",
    "    #computations_noisyGD.optimize_all_base_lrs(x0, change_eta=True, eta_range=eta_range, save_results=False, plot=False)\n",
    "    computations_noisyGD.adapt_eta_from_file(filename=computations_SGD.last_optimization_file)\n",
    "\n",
    "    plot_different_models(x0, [computations_SGD, computations_noisyGD], savefig=False, log_scale=True, title=f\"Optimal eta comparison for exponent={exponent:.2f}\")"
   ]
  },
